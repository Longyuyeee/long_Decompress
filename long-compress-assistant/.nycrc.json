{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "check-coverage": true,
  "reporter": ["text", "json", "html", "lcov"],
  "exclude": [
    "**/*.d.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/__tests__/**",
    "**/__mocks__/**",
    "coverage/**",
    "dist/**",
    "node_modules/**",
    "src-tauri/**",
    "tests/**",
    "*.config.js",
    "*.config.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.js"
  ],
  "watermarks": {
    "lines": [80, 95],
    "functions": [80, 95],
    "branches": [80, 95],
    "statements": [80, 95]
  },
  "report-dir": "coverage",
  "temp-dir": ".nyc_output"
}