{
  "productName": "胧压缩·方便助手",
  "version": "0.1.0",
  "identifier": "com.longcompress.assistant",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "胧压缩·方便助手",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright © 2026 胧压缩·方便助手",
    "category": "Utility",
    "shortDescription": "智能压缩解压助手",
    "longDescription": "支持多种格式、密码本管理、批量处理的现代化压缩解压工具"
  },
  "plugins": {
    "shell": {
      "open": true,
      "execute": true
    }
  }
}