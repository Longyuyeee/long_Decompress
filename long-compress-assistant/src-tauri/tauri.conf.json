{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "胧压缩·方便助手",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": false,
      "targets": "all",
      "identifier": "com.longcompress.assistant",
      "icon": [],
      "resources": [],
      "externalBin": [],
      "copyright": "Copyright © 2026 胧压缩·方便助手",
      "category": "Utility",
      "shortDescription": "智能压缩解压助手",
      "longDescription": "支持多种格式、密码本管理、批量处理的现代化压缩解压工具"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "胧压缩",
        "width": 800,
        "height": 560,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}